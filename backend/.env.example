# NextHire Backend Environment Variables

# Database
# Local development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./nexthire.db
# Production (PostgreSQL on Railway - set this in Railway dashboard):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Authentication
JWT_SECRET=nexthire-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API - Get key at https://aistudio.google.com/apikey
# Valid keys start with "AIza..."
GOOGLE_API_KEY=your-gemini-api-key-here

# Server
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3001

# File uploads
UPLOAD_DIR=./uploads

# Railway sets this automatically (do NOT set manually):
# PORT=8000
