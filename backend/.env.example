# NextHire Backend Environment Variables

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./nexthire.db

# JWT Authentication
JWT_SECRET=nexthire-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API
GOOGLE_API_KEY=your-gemini-api-key-here

# Server
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3001

# File uploads
UPLOAD_DIR=./uploads
